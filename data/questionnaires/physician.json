{
  "id": "physician-onboarding-v2",
  "provider_type": "physician",
  "version": "2.0.0",
  "taxonomy_version": "1.0.0",
  "display_name": "Physician Onboarding Questionnaire",
  "description": "Complete onboarding for Physician (MD, DO) CareAgents \u2014 identity, credentials, scope, and autonomy.",
  "authority": "axon",
  "target_type": "provider",
  "classification": {
    "domain": "clinical",
    "sensitivity": "sensitive"
  },
  "output_artifact": "cans",
  "llm_system_prompt": "You are CareAgent, conducting a structured provider onboarding interview for a physician. Present each question exactly as specified. Do not improvise, skip, or reorder questions. Be professional, warm, and concise. When NPI lookup returns data, present it for confirmation rather than re-asking. For optional questions, accept 'skip' or 'no' gracefully.",
  "completion_criteria": "All required fields collected: identity (NPI + name), credentials, specialty, scope of practice, clinical philosophy, and autonomy tiers for all 7 actions.",
  "sections": [
    {
      "id": "identity",
      "title": "Provider Identity",
      "description": "NPI verification and provider identification.",
      "question_ids": [
        "individual_npi",
        "provider_name",
        "organization_npi",
        "organization_name"
      ]
    },
    {
      "id": "credentials",
      "title": "Credentials",
      "description": "Professional degrees, licenses, and certifications.",
      "question_ids": [
        "license_primary_state_confirm",
        "license_active",
        "license_number_confirm",
        "has_certifications",
        "certifications_list"
      ]
    },
    {
      "id": "specialty",
      "title": "Specialty",
      "description": "Medical specialty and subspecialty information.",
      "question_ids": [
        "has_subspecialty",
        "subspecialty_list"
      ]
    },
    {
      "id": "scope",
      "title": "Scope of Practice",
      "description": "Clinical activities and permitted actions for the AI agent.",
      "question_ids": [
        "practice_setting",
        "clinical_charting",
        "prescribing",
        "dea_number",
        "controlled_substances",
        "diagnostic_ordering",
        "results_interpretation",
        "patient_education",
        "care_coordination",
        "billing"
      ]
    },
    {
      "id": "autonomy",
      "title": "Autonomy Configuration",
      "description": "Per-action autonomy tiers controlling CareAgent's independence.",
      "question_ids": [
        "autonomy_chart",
        "autonomy_order",
        "autonomy_charge",
        "autonomy_interpret",
        "autonomy_educate",
        "autonomy_coordinate"
      ]
    }
  ],
  "questions": [
    {
      "id": "individual_npi",
      "text": "What is your personal NPI number (10 digits)?",
      "answer_type": "text",
      "required": true,
      "npi_lookup": true,
      "cans_field": "provider.npi",
      "validation": {
        "pattern": "^\\d{10}$"
      },
      "llm_guidance": "Ask for their personal NPI number (NPI-1), not their organization's NPI-2. The number is exactly 10 digits. After lookup, check the returned status field. If status is NOT 'active', inform the provider that their NPI is not in active status and onboarding cannot continue. Do not proceed to further questions. If status is 'active', auto-store enumeration_type, status, first_name, last_name, credential, specialty, taxonomy_code, practice_state, and practice_city from the lookup response and continue.",
      "classification": {
        "domain": "clinical",
        "sensitivity": "sensitive"
      },
      "mode": "structured"
    },
    {
      "id": "provider_name",
      "text": "What is your full name as it appears on your medical license?",
      "answer_type": "text",
      "required": true,
      "npi_prefill": "npi_lookup.name",
      "cans_field": "provider.name",
      "validation": {
        "min_length": 2
      },
      "llm_guidance": "If the NPI lookup returned a name, present it for confirmation: 'NPI lookup shows your name as [name]. Is this correct?' If they confirm, use that name. If not, ask them to provide the correct name.",
      "classification": {
        "domain": "clinical",
        "sensitivity": "sensitive"
      },
      "mode": "structured"
    },
    {
      "id": "organization_npi",
      "text": "What is your practice NPI (10 digits)?",
      "answer_type": "text",
      "required": true,
      "npi_lookup": true,
      "cans_field": "provider.organizations",
      "validation": {
        "pattern": "^\\d{10}$"
      },
      "llm_guidance": "This is the organization NPI (NPI-2), separate from their personal NPI-1. Every actively practicing physician should have a practice NPI. After lookup, auto-store ALL returned data: organization_name (legal name), dba_name, enumeration_type, status, authorized_official, taxonomies, primary_address, mailing_address, practice_locations, and certification_date. The next question will present the DBA name for confirmation.",
      "classification": {
        "domain": "administrative",
        "sensitivity": "non_sensitive"
      },
      "mode": "structured"
    },
    {
      "id": "organization_name",
      "text": "Is {{npi_org_lookup.organization_name}} your practice name?",
      "answer_type": "boolean",
      "required": true,
      "npi_prefill": "npi_org_lookup.organization_name",
      "cans_field": "provider.organizations",
      "llm_guidance": "Present the DBA (Doing Business As) name from the NPI-2 lookup: 'The NPI you entered returned the practice name {{npi_org_lookup.organization_name}}. Is this correct?' If no DBA exists, fall back to the legal organization_name. If they confirm, store and continue. If they deny, explain that the practice name is tied to the NPI number they entered, and ask them to re-enter their practice NPI. Loop back to the practice NPI question (organization_npi). After 5 failed attempts, say: 'It looks like there is a mismatch with the NPI number you are entering and your practice name. Please verify your practice NPI and try again.' Continue the loop \u2014 the provider cannot proceed until the practice NPI and name match.",
      "classification": {
        "domain": "administrative",
        "sensitivity": "non_sensitive"
      },
      "mode": "structured"
    },
    {
      "id": "license_primary_state_confirm",
      "text": "Is {{npi_lookup.license_state}} your primary practice state?",
      "answer_type": "boolean",
      "required": true,
      "cans_field": "provider.licenses",
      "hard_stop": {
        "operator": "equals",
        "value": "false",
        "message": "Your primary practice state could not be confirmed. Onboarding cannot continue."
      },
      "llm_guidance": "Ask: 'Is {{npi_lookup.license_state}} your primary practice state?' This uses the primary license state from the NPI lookup. If they answer no, onboarding stops.",
      "classification": {
        "domain": "clinical",
        "sensitivity": "sensitive"
      },
      "mode": "structured"
    },
    {
      "id": "license_active_primary",
      "text": "Is your {{npi_lookup.license_state}} medical license active?",
      "answer_type": "boolean",
      "required": true,
      "cans_field": "provider.licenses",
      "hard_stop": {
        "operator": "equals",
        "value": "false",
        "message": "Your primary medical license is not active. Onboarding cannot continue."
      },
      "llm_guidance": "Ask about their primary license state from the NPI lookup. If not active, hard stop.",
      "classification": {
        "domain": "clinical",
        "sensitivity": "sensitive"
      },
      "mode": "structured"
    },
    {
      "id": "license_number_primary",
      "text": "What is your {{npi_lookup.license_state}} license number?",
      "answer_type": "text",
      "required": true,
      "cans_field": "provider.licenses",
      "validation": {
        "min_length": 1
      },
      "hard_stop": {
        "operator": "mismatch",
        "compare_to": "npi_lookup.license_number",
        "message": "The license number you entered does not match NPPES records. Onboarding cannot continue."
      },
      "llm_guidance": "Ask for their primary license number. Validated against NPI lookup.",
      "classification": {
        "domain": "clinical",
        "sensitivity": "sensitive"
      },
      "mode": "structured"
    },
    {
      "id": "has_certifications",
      "text": "Do you hold any board certifications?",
      "answer_type": "boolean",
      "required": true,
      "classification": {
        "domain": "clinical",
        "sensitivity": "non_sensitive"
      },
      "mode": "structured"
    },
    {
      "id": "certifications_list",
      "text": "List your certification(s) (comma-separated, e.g., ABNS Board Certified):",
      "answer_type": "text",
      "required": true,
      "show_when": {
        "question_id": "has_certifications",
        "operator": "equals",
        "value": "true"
      },
      "cans_field": "provider.certifications",
      "validation": {
        "min_length": 1
      },
      "classification": {
        "domain": "clinical",
        "sensitivity": "non_sensitive"
      },
      "mode": "structured"
    },
    {
      "id": "has_subspecialty",
      "text": "Do you have a subspecialty?",
      "answer_type": "boolean",
      "required": true,
      "classification": {
        "domain": "clinical",
        "sensitivity": "non_sensitive"
      },
      "mode": "structured"
    },
    {
      "id": "subspecialty_list",
      "text": "List your subspecialty or subspecialties (comma-separated, e.g., Spine, Electrophysiology):",
      "answer_type": "text",
      "required": true,
      "show_when": {
        "question_id": "has_subspecialty",
        "operator": "equals",
        "value": "true"
      },
      "cans_field": "provider.subspecialties",
      "validation": {
        "min_length": 2
      },
      "classification": {
        "domain": "clinical",
        "sensitivity": "non_sensitive"
      },
      "mode": "structured"
    },
    {
      "id": "practice_setting",
      "text": "What is your primary practice setting?",
      "answer_type": "single_select",
      "required": true,
      "options": [
        {
          "value": "academic",
          "label": "1. Academic/Teaching",
          "description": "University-affiliated or teaching hospital"
        },
        {
          "value": "private",
          "label": "2. Private Practice",
          "description": "Solo or group private practice"
        },
        {
          "value": "hospital",
          "label": "3. Hospital-Employed",
          "description": "Employed by a hospital or health system"
        },
        {
          "value": "government",
          "label": "4. Government/Military",
          "description": "VA, military, or government-affiliated facility"
        }
      ],
      "cans_field": "scope.practice_setting",
      "classification": {
        "domain": "administrative",
        "sensitivity": "non_sensitive"
      },
      "mode": "structured"
    },
    {
      "id": "clinical_charting",
      "text": "Do you document clinical encounters (progress notes, H&P, consultation notes)?",
      "answer_type": "boolean",
      "required": true,
      "cans_field": "scope.permitted_actions",
      "action_assignments": [
        {
          "answer_value": "true",
          "grants": [
            "chart.progress_note",
            "chart.history_and_physical",
            "chart.consultation_note",
            "chart.communication",
            "chart.referral_letter"
          ]
        }
      ],
      "classification": {
        "domain": "clinical",
        "sensitivity": "non_sensitive"
      },
      "mode": "structured"
    },
    {
      "id": "prescribing",
      "text": "Do you prescribe medications?",
      "answer_type": "boolean",
      "required": true,
      "cans_field": "scope.permitted_actions",
      "action_assignments": [
        {
          "answer_value": "true",
          "grants": [
            "order.medication",
            "educate.medication_counseling"
          ]
        }
      ],
      "classification": {
        "domain": "clinical",
        "sensitivity": "non_sensitive"
      },
      "mode": "structured"
    },
    {
      "id": "dea_number",
      "text": "What is your DEA number?",
      "answer_type": "text",
      "required": false,
      "show_when": {
        "question_id": "prescribing",
        "operator": "equals",
        "value": "true"
      },
      "cans_field": "provider.dea_number",
      "validation": {
        "pattern": "^[ABFabf][A-Za-z]\\d{7}$",
        "min_length": 9
      },
      "llm_guidance": "DEV MODE: Accept any input or skip. In production, validate algorithmically: (1) First letter must be A, B, or F for practitioners. (2) Second letter must match the first letter of the provider's last name from NPI lookup. (3) Checksum: add the 1st, 3rd, and 5th digits. Add the 2nd, 4th, and 6th digits and multiply by 2. Sum both results. The last digit of that sum must equal the 7th digit. If any check fails, inform the provider which validation failed and ask them to re-enter.",
      "classification": {
        "domain": "clinical",
        "sensitivity": "sensitive"
      },
      "mode": "structured"
    },
    {
      "id": "controlled_substances",
      "text": "Do you prescribe controlled substances (DEA-scheduled)?",
      "answer_type": "boolean",
      "required": true,
      "show_when": {
        "question_id": "prescribing",
        "operator": "equals",
        "value": "true"
      },
      "cans_field": "scope.permitted_actions",
      "action_assignments": [
        {
          "answer_value": "true",
          "grants": [
            "order.controlled_substance"
          ]
        }
      ],
      "classification": {
        "domain": "clinical",
        "sensitivity": "sensitive"
      },
      "mode": "structured"
    },
    {
      "id": "diagnostic_ordering",
      "text": "Do you order diagnostic tests (lab work, imaging)?",
      "answer_type": "boolean",
      "required": true,
      "cans_field": "scope.permitted_actions",
      "action_assignments": [
        {
          "answer_value": "true",
          "grants": [
            "order.laboratory",
            "order.imaging"
          ]
        }
      ],
      "classification": {
        "domain": "clinical",
        "sensitivity": "non_sensitive"
      },
      "mode": "structured"
    },
    {
      "id": "results_interpretation",
      "text": "Do you interpret diagnostic results (lab values, imaging, EKG)?",
      "answer_type": "boolean",
      "required": true,
      "cans_field": "scope.permitted_actions",
      "action_assignments": [
        {
          "answer_value": "true",
          "grants": [
            "interpret.laboratory_result",
            "interpret.imaging_study",
            "interpret.electrocardiogram",
            "interpret.pathology_report"
          ]
        }
      ],
      "classification": {
        "domain": "clinical",
        "sensitivity": "non_sensitive"
      },
      "mode": "structured"
    },
    {
      "id": "patient_education",
      "text": "Do you provide patient education and discharge planning?",
      "answer_type": "boolean",
      "required": true,
      "cans_field": "scope.permitted_actions",
      "action_assignments": [
        {
          "answer_value": "true",
          "grants": [
            "educate.patient_education",
            "educate.discharge_instructions",
            "educate.informed_consent"
          ]
        }
      ],
      "classification": {
        "domain": "clinical",
        "sensitivity": "non_sensitive"
      },
      "mode": "structured"
    },
    {
      "id": "care_coordination",
      "text": "Do you coordinate care with other providers (referrals, transitions, team conferences)?",
      "answer_type": "boolean",
      "required": true,
      "cans_field": "scope.permitted_actions",
      "action_assignments": [
        {
          "answer_value": "true",
          "grants": [
            "coordinate.referral",
            "coordinate.care_transition",
            "coordinate.multidisciplinary_conference"
          ]
        }
      ],
      "classification": {
        "domain": "clinical",
        "sensitivity": "non_sensitive"
      },
      "mode": "structured"
    },
    {
      "id": "billing",
      "text": "Do you submit professional billing/coding?",
      "answer_type": "boolean",
      "required": true,
      "cans_field": "scope.permitted_actions",
      "action_assignments": [
        {
          "answer_value": "true",
          "grants": [
            "charge.evaluation_management",
            "charge.procedure_coding",
            "charge.diagnosis_coding"
          ]
        }
      ],
      "classification": {
        "domain": "administrative",
        "sensitivity": "non_sensitive"
      },
      "mode": "structured"
    },
    {
      "id": "autonomy_chart",
      "text": "What autonomy level for clinical documentation (charting)?",
      "answer_type": "single_select",
      "required": true,
      "options": [
        {
          "value": "autonomous",
          "label": "Autonomous",
          "description": "CareAgent acts independently, you review afterward"
        },
        {
          "value": "supervised",
          "label": "Supervised",
          "description": "CareAgent prepares the work, you approve before execution"
        },
        {
          "value": "manual",
          "label": "Manual",
          "description": "You must explicitly initiate, CareAgent only assists when asked"
        }
      ],
      "cans_field": "autonomy.chart",
      "llm_guidance": "Most providers choose 'autonomous' for charting. Explain the three tiers clearly.",
      "classification": {
        "domain": "administrative",
        "sensitivity": "non_sensitive"
      },
      "mode": "structured"
    },
    {
      "id": "autonomy_order",
      "text": "What autonomy level for orders (medications, labs, imaging)?",
      "answer_type": "single_select",
      "required": true,
      "options": [
        {
          "value": "supervised",
          "label": "1. Supervised",
          "description": "CareAgent prepares, you approve"
        },
        {
          "value": "manual",
          "label": "2. Manual",
          "description": "You initiate, CareAgent assists"
        }
      ],
      "cans_field": "autonomy.order",
      "llm_guidance": "Orders cannot be autonomous \u2014 only Supervised or Manual. Most providers choose Supervised.",
      "classification": {
        "domain": "administrative",
        "sensitivity": "non_sensitive"
      },
      "mode": "structured"
    },
    {
      "id": "autonomy_charge",
      "text": "What autonomy level for billing and coding?",
      "answer_type": "single_select",
      "required": true,
      "options": [
        {
          "value": "autonomous",
          "label": "Autonomous",
          "description": "CareAgent acts independently"
        },
        {
          "value": "supervised",
          "label": "Supervised",
          "description": "CareAgent prepares, you approve"
        },
        {
          "value": "manual",
          "label": "Manual",
          "description": "You initiate, CareAgent assists"
        }
      ],
      "cans_field": "autonomy.charge",
      "classification": {
        "domain": "administrative",
        "sensitivity": "non_sensitive"
      },
      "mode": "structured"
    },
    {
      "id": "autonomy_interpret",
      "text": "What autonomy level for result interpretation?",
      "answer_type": "single_select",
      "required": true,
      "options": [
        {
          "value": "supervised",
          "label": "1. Supervised",
          "description": "CareAgent prepares, you approve"
        },
        {
          "value": "manual",
          "label": "2. Manual",
          "description": "You initiate, CareAgent assists"
        }
      ],
      "cans_field": "autonomy.interpret",
      "llm_guidance": "Result interpretation cannot be autonomous \u2014 only Supervised or Manual.",
      "classification": {
        "domain": "administrative",
        "sensitivity": "non_sensitive"
      },
      "mode": "structured"
    },
    {
      "id": "autonomy_educate",
      "text": "What autonomy level for patient education?",
      "answer_type": "single_select",
      "required": true,
      "options": [
        {
          "value": "autonomous",
          "label": "Autonomous",
          "description": "CareAgent acts independently"
        },
        {
          "value": "supervised",
          "label": "Supervised",
          "description": "CareAgent prepares, you approve"
        },
        {
          "value": "manual",
          "label": "Manual",
          "description": "You initiate, CareAgent assists"
        }
      ],
      "cans_field": "autonomy.educate",
      "llm_guidance": "Most providers choose 'autonomous' for patient education.",
      "classification": {
        "domain": "administrative",
        "sensitivity": "non_sensitive"
      },
      "mode": "structured"
    },
    {
      "id": "autonomy_coordinate",
      "text": "What autonomy level for care coordination (referrals, transitions)?",
      "answer_type": "single_select",
      "required": true,
      "options": [
        {
          "value": "autonomous",
          "label": "Autonomous",
          "description": "CareAgent acts independently"
        },
        {
          "value": "supervised",
          "label": "Supervised",
          "description": "CareAgent prepares, you approve"
        },
        {
          "value": "manual",
          "label": "Manual",
          "description": "You initiate, CareAgent assists"
        }
      ],
      "cans_field": "autonomy.coordinate",
      "classification": {
        "domain": "administrative",
        "sensitivity": "non_sensitive"
      },
      "mode": "structured"
    }
  ]
