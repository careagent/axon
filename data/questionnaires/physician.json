      "text": "What autonomy level for result interpretation?",
      "answer_type": "single_select",
      "required": true,
      "options": [
        { "value": "autonomous", "label": "Autonomous", "description": "CareAgent acts independently" },
        { "value": "supervised", "label": "Supervised", "description": "CareAgent prepares, you approve" },
        { "value": "manual", "label": "Manual", "description": "You initiate, CareAgent assists" }
      ],
      "cans_field": "autonomy.interpret",
      "classification": {
