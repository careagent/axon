{
  "id": "physician-onboarding-v2",
  "provider_type": "physician",
  "version": "2.0.0",
  "taxonomy_version": "1.0.0",
  "display_name": "Physician Onboarding Questionnaire",
  "description": "Complete onboarding for Physician (MD, DO) CareAgents — identity, credentials, scope, and autonomy.",
  "authority": "axon",
  "target_type": "provider",
  "classification": {
    "domain": "clinical",
    "sensitivity": "sensitive"
  },
  "output_artifact": "cans",
  "llm_system_prompt": "You are CareAgent, conducting a structured provider onboarding interview for a physician. Present each question exactly as specified. Do not improvise, skip, or reorder questions. Be professional, warm, and concise. When NPI lookup returns data, present it for confirmation rather than re-asking. For optional questions, accept 'skip' or 'no' gracefully.",
  "completion_criteria": "All required fields collected: identity (NPI + name), credentials, specialty, scope of practice, clinical philosophy, and autonomy tiers for all 7 actions.",
  "sections": [
    {
      "id": "identity",
      "title": "Provider Identity",
      "description": "NPI verification and provider identification.",
      "question_ids": ["individual_npi", "provider_name", "organization_npi", "organization_name"]
    },
    {
      "id": "credentials",
      "title": "Credentials",
      "description": "Professional degrees, licenses, and certifications.",
      "question_ids": ["has_additional_types", "additional_types", "has_degrees", "degrees_list", "has_licenses", "licenses_list", "has_certifications", "certifications_list"]
    },
    {
      "id": "specialty",
      "title": "Specialty",
      "description": "Medical specialty and subspecialty information.",
      "question_ids": ["has_specialty", "specialty_list", "has_subspecialty", "subspecialty_list"]
    },
    {
      "id": "scope",
      "title": "Scope of Practice",
      "description": "Clinical activities and permitted actions for the AI agent.",
      "question_ids": ["practice_setting", "supervision_role", "clinical_charting", "prescribing", "dea_number", "controlled_substances", "diagnostic_ordering", "results_interpretation", "clinical_procedures", "patient_education", "care_coordination", "billing"]
    },
    {
      "id": "philosophy",
      "title": "Clinical Philosophy",
      "description": "The provider's approach to clinical AI assistance.",
      "question_ids": ["clinical_philosophy"]
    },
    {
      "id": "voice",
      "title": "Voice Directives",
      "description": "Optional per-action instructions for how CareAgent should behave.",
      "question_ids": ["voice_chart", "voice_educate", "voice_interpret"]
    },
    {
      "id": "autonomy",
      "title": "Autonomy Configuration",
      "description": "Per-action autonomy tiers controlling CareAgent's independence.",
      "question_ids": ["autonomy_chart", "autonomy_order", "autonomy_charge", "autonomy_perform", "autonomy_interpret", "autonomy_educate", "autonomy_coordinate"]
    }
  ],
  "questions": [
    {
      "id": "individual_npi",
      "text": "What is your individual NPI number (10 digits)?",
      "answer_type": "text",
      "required": true,
      "npi_lookup": true,
      "cans_field": "provider.npi",
      "validation": {
        "pattern": "^\\d{10}$"
      },
      "llm_guidance": "Ask for their individual NPI number (NPI-1). This is their personal provider NPI, not their organization's NPI-2. The number is exactly 10 digits.",
      "classification": {
        "domain": "clinical",
        "sensitivity": "sensitive"
      },
      "mode": "structured"
    },
    {
      "id": "provider_name",
      "text": "What is your full name as it appears on your medical license?",
      "answer_type": "text",
      "required": true,
      "npi_prefill": "name",
      "cans_field": "provider.name",
      "validation": {
        "min_length": 2
      },
      "llm_guidance": "If the NPI lookup returned a name, present it for confirmation: 'NPI lookup shows your name as [name]. Is this correct?' If they confirm, use that name. If not, ask them to provide the correct name.",
      "classification": {
        "domain": "clinical",
        "sensitivity": "sensitive"
      },
      "mode": "structured"
    },
    {
      "id": "organization_npi",
      "text": "What is your practice or organization NPI (10 digits)? You may skip if unknown.",
      "answer_type": "text",
      "required": false,
      "npi_lookup": true,
      "cans_field": "provider.organizations",
      "validation": {
        "pattern": "^\\d{10}$"
      },
      "llm_guidance": "This is the organization NPI (NPI-2), separate from their individual NPI-1. It's optional — if they don't know it or are in solo practice, they can skip.",
      "classification": {
        "domain": "administrative",
        "sensitivity": "non_sensitive"
      },
      "mode": "structured"
    },
    {
      "id": "organization_name",
      "text": "What is the name of your practice or organization?",
      "answer_type": "text",
      "required": true,
      "cans_field": "provider.organizations",
      "validation": {
        "min_length": 2
      },
      "llm_guidance": "If the organization NPI lookup returned a name, present it for confirmation. Otherwise, ask them to type their practice or organization name.",
      "classification": {
        "domain": "administrative",
        "sensitivity": "non_sensitive"
      },
      "mode": "structured"
    },
    {
      "id": "has_additional_types",
      "text": "Do you hold any additional provider types beyond Physician (MD/DO)?",
      "answer_type": "boolean",
      "required": true,
      "llm_guidance": "Some physicians also hold other provider type credentials (e.g., a physician who is also a licensed acupuncturist). Most will answer no.",
      "classification": {
        "domain": "clinical",
        "sensitivity": "non_sensitive"
      },
      "mode": "structured"
    },
    {
      "id": "additional_types",
      "text": "List your additional provider types (comma-separated):",
      "answer_type": "text",
      "required": true,
      "show_when": {
        "question_id": "has_additional_types",
        "operator": "equals",
        "value": "true"
      },
      "cans_field": "provider.types",
      "validation": {
        "min_length": 2
      },
      "classification": {
        "domain": "clinical",
        "sensitivity": "non_sensitive"
      },
      "mode": "structured"
    },
    {
      "id": "has_degrees",
      "text": "Do you hold any medical degrees (MD, DO, etc.)?",
      "answer_type": "boolean",
      "required": true,
      "npi_prefill": "credential",
      "llm_guidance": "If NPI lookup returned credential information, present it: 'NPI records show credential [credential]. Do you hold a medical degree?' Most physicians will answer yes.",
      "classification": {
        "domain": "clinical",
        "sensitivity": "non_sensitive"
      },
      "mode": "structured"
    },
    {
      "id": "degrees_list",
      "text": "List your degree(s) (comma-separated, e.g., MD, DO):",
      "answer_type": "text",
      "required": true,
      "show_when": {
        "question_id": "has_degrees",
        "operator": "equals",
        "value": "true"
      },
      "npi_prefill": "credential",
      "cans_field": "provider.degrees",
      "validation": {
        "min_length": 1
      },
      "llm_guidance": "If NPI lookup returned a credential, pre-fill it: 'NPI shows [credential]. Please confirm or add additional degrees.'",
      "classification": {
        "domain": "clinical",
        "sensitivity": "non_sensitive"
      },
      "mode": "structured"
    },
    {
      "id": "has_licenses",
      "text": "Do you hold any active medical licenses?",
      "answer_type": "boolean",
      "required": true,
      "npi_prefill": "license",
      "llm_guidance": "If NPI lookup returned license information, present it: 'NPI records show licenses in [states]. Do you hold active medical licenses?' Most physicians will answer yes.",
      "classification": {
        "domain": "clinical",
        "sensitivity": "sensitive"
      },
      "mode": "structured"
    },
    {
      "id": "licenses_list",
      "text": "List your license(s) (comma-separated, e.g., SC-25231, TX-MD-98765):",
      "answer_type": "text",
      "required": true,
      "show_when": {
        "question_id": "has_licenses",
        "operator": "equals",
        "value": "true"
      },
      "npi_prefill": "license",
      "cans_field": "provider.licenses",
      "validation": {
        "min_length": 1
      },
      "llm_guidance": "If NPI lookup returned license data, present the licenses for confirmation: 'NPI shows the following licenses: [licenses]. Please confirm, correct, or add additional licenses.'",
      "classification": {
        "domain": "clinical",
        "sensitivity": "sensitive"
      },
      "mode": "structured"
    },
    {
      "id": "has_certifications",
      "text": "Do you hold any board certifications?",
      "answer_type": "boolean",
      "required": true,
      "classification": {
        "domain": "clinical",
        "sensitivity": "non_sensitive"
      },
      "mode": "structured"
    },
    {
      "id": "certifications_list",
      "text": "List your certification(s) (comma-separated, e.g., ABNS Board Certified):",
      "answer_type": "text",
      "required": true,
      "show_when": {
        "question_id": "has_certifications",
        "operator": "equals",
        "value": "true"
      },
      "cans_field": "provider.certifications",
      "validation": {
        "min_length": 1
      },
      "classification": {
        "domain": "clinical",
        "sensitivity": "non_sensitive"
      },
      "mode": "structured"
    },
    {
      "id": "has_specialty",
      "text": "Do you have a primary medical specialty?",
      "answer_type": "boolean",
      "required": true,
      "npi_prefill": "specialty",
      "llm_guidance": "If NPI lookup returned specialty information, present it: 'NPI records show your specialty as [specialty]. Is this correct?'",
      "classification": {
        "domain": "clinical",
        "sensitivity": "non_sensitive"
      },
      "mode": "structured"
    },
    {
      "id": "specialty_list",
      "text": "List your specialty or specialties (comma-separated, e.g., Neurosurgery, Internal Medicine):",
      "answer_type": "text",
      "required": true,
      "show_when": {
        "question_id": "has_specialty",
        "operator": "equals",
        "value": "true"
      },
      "npi_prefill": "specialty",
      "cans_field": "provider.specialties",
      "validation": {
        "min_length": 2
      },
      "llm_guidance": "If NPI lookup returned a specialty, pre-fill it for confirmation. The provider may have multiple specialties.",
      "classification": {
        "domain": "clinical",
        "sensitivity": "non_sensitive"
      },
      "mode": "structured"
    },
    {
      "id": "has_subspecialty",
      "text": "Do you have a subspecialty?",
      "answer_type": "boolean",
      "required": true,
      "classification": {
        "domain": "clinical",
        "sensitivity": "non_sensitive"
      },
      "mode": "structured"
    },
    {
      "id": "subspecialty_list",
      "text": "List your subspecialty or subspecialties (comma-separated, e.g., Spine, Electrophysiology):",
      "answer_type": "text",
      "required": true,
      "show_when": {
        "question_id": "has_subspecialty",
        "operator": "equals",
        "value": "true"
      },
      "cans_field": "provider.subspecialties",
      "validation": {
        "min_length": 2
      },
      "classification": {
        "domain": "clinical",
        "sensitivity": "non_sensitive"
      },
      "mode": "structured"
    },
    {
      "id": "practice_setting",
      "text": "What is your primary practice setting?",
      "answer_type": "single_select",
      "required": true,
      "options": [
        {
          "value": "academic",
          "label": "Academic/Teaching",
          "description": "University-affiliated or teaching hospital"
        },
        {
          "value": "private",
          "label": "Private Practice",
          "description": "Solo or group private practice"
        },
        {
          "value": "hospital",
          "label": "Hospital-Employed",
          "description": "Employed by a hospital or health system"
        },
        {
          "value": "government",
          "label": "Government/Military",
          "description": "VA, military, or government-affiliated facility"
        }
      ],
      "cans_field": "scope.practice_setting",
      "classification": {
        "domain": "administrative",
        "sensitivity": "non_sensitive"
      },
      "mode": "structured"
    },
    {
      "id": "supervision_role",
      "text": "Do you supervise residents or fellows?",
      "answer_type": "boolean",
      "required": true,
      "show_when": {
        "question_id": "practice_setting",
        "operator": "equals",
        "value": "academic"
      },
      "cans_field": "scope.supervision_level",
      "classification": {
        "domain": "administrative",
        "sensitivity": "non_sensitive"
      },
      "mode": "structured"
    },
    {
      "id": "clinical_charting",
      "text": "Do you document clinical encounters (progress notes, H&P, consultation notes)?",
      "answer_type": "boolean",
      "required": true,
      "cans_field": "scope.permitted_actions",
      "action_assignments": [
        {
          "answer_value": "true",
          "grants": [
            "chart.progress_note",
            "chart.history_and_physical",
            "chart.consultation_note",
            "chart.communication",
            "chart.referral_letter"
          ]
        }
      ],
      "classification": {
        "domain": "clinical",
        "sensitivity": "non_sensitive"
      },
      "mode": "structured"
    },
    {
      "id": "prescribing",
      "text": "Do you prescribe medications?",
      "answer_type": "boolean",
      "required": true,
      "cans_field": "scope.permitted_actions",
      "action_assignments": [
        {
          "answer_value": "true",
          "grants": [
            "order.medication",
            "educate.medication_counseling"
          ]
        }
      ],
      "classification": {
        "domain": "clinical",
        "sensitivity": "non_sensitive"
      },
      "mode": "structured"
    },
    {
      "id": "dea_number",
      "text": "What is your DEA number?",
      "answer_type": "text",
      "required": true,
      "show_when": {
        "question_id": "prescribing",
        "operator": "equals",
        "value": "true"
      },
      "cans_field": "provider.dea_number",
      "validation": {
        "pattern": "^[A-Z]{2}\\d{7}$",
        "min_length": 9
      },
      "llm_guidance": "DEA numbers are exactly 9 characters: 2 uppercase letters followed by 7 digits (e.g., AB1234567).",
      "classification": {
        "domain": "clinical",
        "sensitivity": "sensitive"
      },
      "mode": "structured"
    },
    {
      "id": "controlled_substances",
      "text": "Do you prescribe controlled substances (DEA-scheduled)?",
      "answer_type": "boolean",
      "required": true,
      "show_when": {
        "question_id": "prescribing",
        "operator": "equals",
        "value": "true"
      },
      "cans_field": "scope.permitted_actions",
      "action_assignments": [
        {
          "answer_value": "true",
          "grants": [
            "order.controlled_substance"
          ]
        }
      ],
      "classification": {
        "domain": "clinical",
        "sensitivity": "sensitive"
      },
      "mode": "structured"
    },
    {
      "id": "diagnostic_ordering",
      "text": "Do you order diagnostic tests (lab work, imaging)?",
      "answer_type": "boolean",
      "required": true,
      "cans_field": "scope.permitted_actions",
      "action_assignments": [
        {
          "answer_value": "true",
          "grants": [
            "order.laboratory",
            "order.imaging"
          ]
        }
      ],
      "classification": {
        "domain": "clinical",
        "sensitivity": "non_sensitive"
      },
      "mode": "structured"
    },
    {
      "id": "results_interpretation",
      "text": "Do you interpret diagnostic results (lab values, imaging, EKG)?",
      "answer_type": "boolean",
      "required": true,
      "cans_field": "scope.permitted_actions",
      "action_assignments": [
        {
          "answer_value": "true",
          "grants": [
            "interpret.laboratory_result",
            "interpret.imaging_study",
            "interpret.electrocardiogram",
            "interpret.pathology_report"
          ]
        }
      ],
      "classification": {
        "domain": "clinical",
        "sensitivity": "non_sensitive"
      },
      "mode": "structured"
    },
    {
      "id": "clinical_procedures",
      "text": "Do you perform clinical procedures (injections, biopsies, laceration repair)?",
      "answer_type": "boolean",
      "required": true,
      "cans_field": "scope.permitted_actions",
      "action_assignments": [
        {
          "answer_value": "true",
          "grants": [
            "order.procedure",
            "perform.physical_exam"
          ]
        }
      ],
      "classification": {
        "domain": "clinical",
        "sensitivity": "non_sensitive"
      },
      "mode": "structured"
    },
    {
      "id": "patient_education",
      "text": "Do you provide patient education and discharge planning?",
      "answer_type": "boolean",
      "required": true,
      "cans_field": "scope.permitted_actions",
      "action_assignments": [
        {
          "answer_value": "true",
          "grants": [
            "educate.patient_education",
            "educate.discharge_instructions",
            "educate.informed_consent"
          ]
        }
      ],
      "classification": {
        "domain": "clinical",
        "sensitivity": "non_sensitive"
      },
      "mode": "structured"
    },
    {
      "id": "care_coordination",
      "text": "Do you coordinate care with other providers (referrals, transitions, team conferences)?",
      "answer_type": "boolean",
      "required": true,
      "cans_field": "scope.permitted_actions",
      "action_assignments": [
        {
          "answer_value": "true",
          "grants": [
            "coordinate.referral",
            "coordinate.care_transition",
            "coordinate.multidisciplinary_conference"
          ]
        }
      ],
      "classification": {
        "domain": "clinical",
        "sensitivity": "non_sensitive"
      },
      "mode": "structured"
    },
    {
      "id": "billing",
      "text": "Do you submit professional billing/coding?",
      "answer_type": "boolean",
      "required": true,
      "cans_field": "scope.permitted_actions",
      "action_assignments": [
        {
          "answer_value": "true",
          "grants": [
            "charge.evaluation_management",
            "charge.procedure_coding",
            "charge.diagnosis_coding"
          ]
        }
      ],
      "classification": {
        "domain": "administrative",
        "sensitivity": "non_sensitive"
      },
      "mode": "structured"
    },
    {
      "id": "clinical_philosophy",
      "text": "Describe your clinical philosophy — how should your AI assistant approach clinical work?",
      "answer_type": "text",
      "required": true,
      "validation": {
        "min_length": 10
      },
      "llm_guidance": "Ask the provider to describe in their own words how they want their AI assistant to approach clinical decision-making. Encourage them to mention priorities like evidence-based practice, patient autonomy, conservative vs. aggressive approaches, communication style preferences, etc. This is a free-form response — give them space to express their values.",
      "classification": {
        "domain": "clinical",
        "sensitivity": "non_sensitive"
      },
      "mode": "guided"
    },
    {
      "id": "voice_chart",
      "text": "Do you have specific instructions for how CareAgent should handle clinical documentation (charting)?",
      "answer_type": "text",
      "required": false,
      "cans_field": "voice.chart",
      "llm_guidance": "This is optional. Examples: 'Use structured SOAP format', 'Always include assessment and plan', 'Keep notes concise'. If the provider says no or skips, move on.",
      "classification": {
        "domain": "clinical",
        "sensitivity": "non_sensitive"
      },
      "mode": "guided"
    },
    {
      "id": "voice_educate",
      "text": "Do you have specific instructions for how CareAgent should handle patient education?",
      "answer_type": "text",
      "required": false,
      "cans_field": "voice.educate",
      "llm_guidance": "Optional. Examples: 'Include visual diagrams', 'Write at 6th-grade reading level', 'Always mention lifestyle modifications'. If the provider says no or skips, move on.",
      "classification": {
        "domain": "clinical",
        "sensitivity": "non_sensitive"
      },
      "mode": "guided"
    },
    {
      "id": "voice_interpret",
      "text": "Do you have specific instructions for how CareAgent should interpret clinical results?",
      "answer_type": "text",
      "required": false,
      "cans_field": "voice.interpret",
      "llm_guidance": "Optional. Examples: 'Always compare to previous results', 'Flag critical values prominently', 'Include reference ranges'. If the provider says no or skips, move on.",
      "classification": {
        "domain": "clinical",
        "sensitivity": "non_sensitive"
      },
      "mode": "guided"
    },
    {
      "id": "autonomy_chart",
      "text": "What autonomy level for clinical documentation (charting)?",
      "answer_type": "single_select",
      "required": true,
      "options": [
        {
          "value": "autonomous",
          "label": "Autonomous",
          "description": "CareAgent acts independently, you review afterward"
        },
        {
          "value": "supervised",
          "label": "Supervised",
          "description": "CareAgent prepares the work, you approve before execution"
        },
        {
          "value": "manual",
          "label": "Manual",
          "description": "You must explicitly initiate, CareAgent only assists when asked"
        }
      ],
      "cans_field": "autonomy.chart",
      "llm_guidance": "Most providers choose 'autonomous' for charting. Explain the three tiers clearly.",
      "classification": {
        "domain": "administrative",
        "sensitivity": "non_sensitive"
      },
      "mode": "structured"
    },
    {
      "id": "autonomy_order",
      "text": "What autonomy level for orders (medications, labs, imaging)?",
      "answer_type": "single_select",
      "required": true,
      "options": [
        { "value": "autonomous", "label": "Autonomous", "description": "CareAgent acts independently" },
        { "value": "supervised", "label": "Supervised", "description": "CareAgent prepares, you approve" },
